{
  "$schema": "https://gitlab.com/kicad/code/kicad/-/raw/master/pcbnew/pcb_schema.json",
  "meta": {
    "version": "1.0.1",
    "filename": "smart-waterer.kicad_pro"
  },
  "project": {
    "name": "smart-waterer",
    "description": "智能浇花机 v0.4（简化版）",
    "url": "https://github.com/98008033/smart-waterer",
    "author": "Smart Waterer Team",
    "date": "2026-03-13",
    "revision": "v0.4"
  },
  "board": {
    "file": "smart-waterer.kicad_pcb",
    "description": "智能浇花机 PCB v0.4"
  },
  "schematic": {
    "file": "smart-waterer.kicad_sch",
    "description": "智能浇花机原理图 v0.4"
  },
  "3dmodel": {
    "path": "3dmodels"
  },
  "output": {
    "path": "output"
  },
  "design_rules": {
    "rule_severities": {
      "clearance": "error",
      "copper_edge": "error",
      "copper_sliver": "error",
      "courtyards_overlap": "error",
      "diffpair_gap_out_of_tolerance": "error",
      "drill_out_of_range": "error",
      "duplicate_footprints": "error",
      "extra_footprint": "warning",
      "footprint": "error",
      "footprint_symbol_mismatch": "error",
      "hole_clearance": "error",
      "hole_near_hole": "error",
      "invalid_outline": "error",
      "isolated_copper": "warning",
      "item_on_disabled_layer": "error",
      "items_not_allowed": "error",
      "length_out_of_tolerance": "error",
      "lib_symbol_issues": "error",
      "missing_bidi_pin": "warning",
      "missing_footprint": "error",
      "missing_layer": "error",
      "missing_symbol": "error",
      "net_conflict": "error",
      "npth_connected_to_copper": "error",
      "npth_to_copper": "error",
      "padstack": "error",
      "silk_edge": "error",
      "silk_overlap": "error",
      "silk_pin1": "warning",
      "silk_screen_clearance": "error",
      "text_height": "warning",
      "text_thickness": "warning",
      "through_hole_pad_without_hole": "error",
      "too_many_vias": "error",
      "track_dangling": "warning",
      "track_width": "error",
      "unconnected_items": "error",
      "unresolved_variable": "error",
      "via_dangling": "warning",
      "zones_overlap": "error"
    },
    "rule_severities_defaults": {
      "clearance": "error",
      "track_width": "error",
      "unconnected_items": "error"
    },
    "constraint_rules": {
      "clearance": 0.2,
      "track_width": 0.3,
      "via_diameter": 0.6,
      "via_drill": 0.3,
      "microvia_diameter": 0.3,
      "microvia_drill": 0.15,
      "hole_to_hole": 0.5,
      "hole_clearance": 0.3,
      "edge_clearance": 0.3,
      "silk_clearance": 0.2,
      "copper_to_copper": 0.2,
      "courtyard_clearance": 0.5
    },
    "diff_pair_constraints": [],
    "teardrop_constraints": []
  },
  "libraries": {
    "pinned_footprint_libs": [
      "ESP32-C3-SuperMini",
      "Resistor_SMD",
      "Capacitor_SMD",
      "Diode_SMD",
      "Fuse",
      "Package_SO",
      "Package_TO_SOT_SMD",
      "Connector_USB",
      "TerminalBlock"
    ],
    "pinned_symbol_libs": [
      "Device",
      "Regulator_Linear",
      "Connector"
    ],
    "default_footprint_lib": "ESP32-C3-SuperMini",
    "default_symbol_lib": "Device"
  },
  "net_colors": {
    "nets": {
      "GND": "#000000",
      "3.3V": "#FF0000",
      "USB_5V": "#FF8000",
      "NTC_Temp": "#00FF00",
      "Soil_Moisture": "#0000FF",
      "Water_Level": "#8000FF",
      "Pump_Control": "#FF00FF",
      "Battery_P+": "#FF0080",
      "System_5V": "#FF8080",
      "5V_Out": "#80FF80",
      "Pump_GND": "#808080"
    }
  },
  "pcbnew": {
    "last_paths": {
      "gencad": "",
      "idf": "",
      "vrml": "",
      "dxf": "",
      "gerber": "",
      "gerber_job": "",
      "ipc_d356": "",
      "netlist": "",
      "pdf": "",
      "postscript": "",
      "svg": ""
    }
  },
  "eeschema": {
    "annotation_order": "ascending_x_then_y",
    "last_paths": {
      "bom": "",
      "cmp": "",
      "netlist": "",
      "pcb": "",
      "plot": "",
      "plot_dir": "",
      "schematic": "",
      "svg": "",
      "xml": ""
    }
  },
  "erc": {
    "meta": {
      "version": "1.0.0"
    },
    "erc_exclusions": [
      "pin_not_connected"
    ],
    "erc_severities": {
      "conflicting_pins": "error",
      "duplicate_reference": "error",
      "duplicate_sheet_name": "error",
      "endpoint_off_grid": "warning",
      "global_label_dangling": "warning",
      "hierarchical_label_dangling": "warning",
      "label_dangling": "error",
      "lib_symbol_issues": "error",
      "missing_bidi_pin": "warning",
      "missing_input_pin": "error",
      "missing_power_pin": "error",
      "missing_unit": "error",
      "net_not_bus_member": "warning",
      "no_connect_connected": "warning",
      "no_connect_dangling": "warning",
      "pin_connected_to_label": "warning",
      "pin_not_connected": "warning",
      "pin_not_driven": "error",
      "pin_to_pin": "warning",
      "similar_labels": "warning",
      "unannotated": "error",
      "unit_value_mismatch": "error",
      "unresolved_variable": "error",
      "wire_dangling": "warning"
    }
  },
  "board_setup": {
    "auto_place": {
      "place_free_angle": false,
      "place_radius": 5
    },
    "board": {
      "outline_line_width": 0.05
    },
    "defaults": {
      "board_outline_line_width": 0.05,
      "copper_line_width": 0.2,
      "copper_text_italic": false,
      "copper_text_size_h": 1.5,
      "copper_text_size_v": 1.5,
      "copper_text_thickness": 0.3,
      "dimension_precision": 4,
      "dimension_units": 3,
      "fab_line_width": 0.1,
      "fab_text_italic": false,
      "fab_text_size_h": 1.0,
      "fab_text_size_v": 1.0,
      "fab_text_thickness": 0.15,
      "other_line_width": 0.15,
      "other_text_italic": false,
      "other_text_size_h": 1.0,
      "other_text_size_v": 1.0,
      "other_text_thickness": 0.15,
      "silk_line_width": 0.12,
      "silk_text_italic": false,
      "silk_text_size_h": 1.0,
      "silk_text_size_v": 1.0,
      "silk_text_thickness": 0.12
    },
    "design_rules": {
      "rule_severities": {
        "clearance": "error",
        "track_width": "error"
      },
      "constraint_rules": {
        "clearance": 0.2,
        "track_width": 0.3
      }
    },
    "layer_presets": [],
    "text_presets": {},
    "via_presets": [
      {
        "name": "Default Via",
        "diameter": 0.6,
        "drill": 0.3
      },
      {
        "name": "Small Via",
        "diameter": 0.4,
        "drill": 0.2
      },
      {
        "name": "Large Via",
        "diameter": 0.8,
        "drill": 0.4
      }
    ]
  },
  "project_file_version": 1
}

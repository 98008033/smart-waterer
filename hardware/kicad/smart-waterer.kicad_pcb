(kicad_pcb
  (version 20240108)
  (generator pcbnew)

  (general
    (thickness 1.6)
  )

  (paper "A4")

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (42 "Eco1.User" user)
    (43 "Eco2.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (pad_to_mask_clearance 0)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros false)
      (usegerberextensions false)
      (usegerberattributes true)
      (usegerberadvancedattributes true)
      (creategerberjobfile true)
      (dxfprecision 12)
      (gerberprecision 12)
      (svgprecision 6)
      (plotframeref false)
      (viasonmask false)
      (mode 1)
      (useauxorigin false)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups true)
      (pdf_back_fp_property_popups true)
      (dxfpolygonmode true)
      (dxfimperialunits true)
      (dxfusepcbnewfont true)
      (psnegative false)
      (psa4output false)
      (plotreference true)
      (plotvalue true)
      (plotinvisibletext false)
      (sketchnctestonfaboutput false)
      (plotpadnumbers true)
      (plotrefonly false)
      (subtractmaskfromsilk false)
      (outputformat 1)
      (mirror false)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "")
    )
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "3.3V")
  (net 3 "USB_5V")
  (net 4 "NTC_Temp")
  (net 5 "Soil_Moisture")
  (net 6 "Water_Level")
  (net 7 "Pump_Control")
  (net 8 "Battery_P+")
  (net 9 "System_5V")
  (net 10 "5V_Out")
  (net 11 "Pump_GND")

  (footprint "ESP32-C3-SuperMini:U1"
    (layer "F.Cu")
    (at 100 50)
    (descr "ESP32-C3 SuperMini Module")
    (tags "ESP32-C3 WiFi BLE")
    (property "Reference" "U1" (at 100 45) (layer "F.SilkS"))
    (property "Value" "ESP32-C3-SuperMini" (at 100 55) (layer "F.Fab"))
    (property "Footprint" "ESP32-C3-SuperMini" (at 100 60) (layer "F.Fab"))
    (property "LCSC" "C2040789" (at 100 65) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Resistor_SMD:R_0805:TH1"
    (layer "F.Cu")
    (at 150 30)
    (descr "NTC 10kΩ B3950")
    (tags "NTC temperature")
    (property "Reference" "TH1" (at 150 25) (layer "F.SilkS"))
    (property "Value" "NTC 10kΩ B3950" (at 150 35) (layer "F.Fab"))
    (property "Footprint" "Resistor_SMD:R_0805" (at 150 40) (layer "F.Fab"))
    (property "LCSC" "C2893625" (at 150 45) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Resistor_SMD:R_0805:R1"
    (layer "F.Cu")
    (at 140 20)
    (descr "10kΩ Pull-up Resistor")
    (tags "resistor pullup")
    (property "Reference" "R1" (at 140 15) (layer "F.SilkS"))
    (property "Value" "10kΩ" (at 140 25) (layer "F.Fab"))
    (property "Footprint" "Resistor_SMD:R_0805" (at 140 30) (layer "F.Fab"))
    (property "LCSC" "C17414" (at 140 35) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Capacitor_SMD:C_0805:C1"
    (layer "F.Cu")
    (at 160 30)
    (descr "100nF Filter Capacitor")
    (tags "capacitor filter")
    (property "Reference" "C1" (at 160 25) (layer "F.SilkS"))
    (property "Value" "100nF" (at 160 35) (layer "F.Fab"))
    (property "Footprint" "Capacitor_SMD:C_0805" (at 160 40) (layer "F.Fab"))
    (property "LCSC" "C1585" (at 160 45) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Diode_SMD:D_SMA:D1"
    (layer "F.Cu")
    (at 50 20)
    (descr "SMAJ5.0A TVS Diode")
    (tags "TVS protection")
    (property "Reference" "D1" (at 50 15) (layer "F.SilkS"))
    (property "Value" "SMAJ5.0A" (at 50 25) (layer "F.Fab"))
    (property "Footprint" "Diode_SMD:D_SMA" (at 50 30) (layer "F.Fab"))
    (property "LCSC" "C117462" (at 50 35) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Fuse:Fuse_1812:F1"
    (layer "F.Cu")
    (at 50 70)
    (descr "1812L110 Resettable Fuse")
    (tags "fuse protection")
    (property "Reference" "F1" (at 50 65) (layer "F.SilkS"))
    (property "Value" "1812L110" (at 50 75) (layer "F.Fab"))
    (property "Footprint" "Fuse:Fuse_1812" (at 50 80) (layer "F.Fab"))
    (property "LCSC" "C318886" (at 50 85) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Package_SO:SOIC-8:Q1"
    (layer "F.Cu")
    (at 200 70)
    (descr "AO4606 N-MOSFET")
    (tags "MOSFET pump driver")
    (property "Reference" "Q1" (at 200 65) (layer "F.SilkS"))
    (property "Value" "AO4606" (at 200 75) (layer "F.Fab"))
    (property "Footprint" "Package_SO:SOIC-8" (at 200 80) (layer "F.Fab"))
    (property "LCSC" "C198134" (at 200 85) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Diode_SMD:D_SOD-323:D2"
    (layer "F.Cu")
    (at 220 70)
    (descr "1N4007 Flyback Diode")
    (tags "diode flyback")
    (property "Reference" "D2" (at 220 65) (layer "F.SilkS"))
    (property "Value" "1N4007" (at 220 75) (layer "F.Fab"))
    (property "Footprint" "Diode_SMD:D_SOD-323" (at 220 80) (layer "F.Fab"))
    (property "LCSC" "C9628" (at 220 85) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Package_TO_SOT_SMD:SOT-23:U2"
    (layer "F.Cu")
    (at 100 100)
    (descr "XC6206-3.3V LDO")
    (tags "LDO regulator 3.3V")
    (property "Reference" "U2" (at 100 95) (layer "F.SilkS"))
    (property "Value" "XC6206-3.3V" (at 100 105) (layer "F.Fab"))
    (property "Footprint" "Package_TO_SOT_SMD:SOT-23" (at 100 110) (layer "F.Fab"))
    (property "LCSC" "C2834053" (at 100 115) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Package_DFN_QFN:DFN-8:U3"
    (layer "F.Cu")
    (at 50 100)
    (descr "TP4056 Charging IC")
    (tags "charger lithium")
    (property "Reference" "U3" (at 50 95) (layer "F.SilkS"))
    (property "Value" "TP4056" (at 50 105) (layer "F.Fab"))
    (property "Footprint" "Package_DFN_QFN:DFN-8" (at 50 110) (layer "F.Fab"))
    (property "LCSC" "C44668" (at 50 115) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Package_TO_SOT_SMD:SOT-23-6:U4"
    (layer "F.Cu")
    (at 150 100)
    (descr "MT3608 Boost Converter")
    (tags "boost converter 5V")
    (property "Reference" "U4" (at 150 95) (layer "F.SilkS"))
    (property "Value" "MT3608" (at 150 105) (layer "F.Fab"))
    (property "Footprint" "Package_TO_SOT_SMD:SOT-23-6" (at 150 110) (layer "F.Fab"))
    (property "LCSC" "C123149" (at 150 115) (layer "F.Fab"))
    (attr smd)
  )

  (footprint "Connector_USB:USB_C_Receptacle:J1"
    (layer "F.Cu")
    (at 50 20)
    (descr "USB-C Receptacle")
    (tags "USB-C charging")
    (property "Reference" "J1" (at 50 15) (layer "F.SilkS"))
    (property "Value" "USB-C" (at 50 25) (layer "F.Fab"))
    (property "Footprint" "Connector_USB:USB_C_Receptacle" (at 50 30) (layer "F.Fab"))
    (property "LCSC" "C165948" (at 50 35) (layer "F.Fab"))
    (attr through_hole)
  )

  (footprint "TerminalBlock:TerminalBlock_KF301-2P:J2"
    (layer "F.Cu")
    (at 120 10)
    (descr "Soil Moisture Sensor")
    (tags "sensor soil")
    (property "Reference" "J2" (at 120 5) (layer "F.SilkS"))
    (property "Value" "土壤湿度" (at 120 15) (layer "F.Fab"))
    (property "Footprint" "TerminalBlock:TerminalBlock_KF301-2P" (at 120 20) (layer "F.Fab"))
    (property "LCSC" "C20959" (at 120 25) (layer "F.Fab"))
    (attr through_hole)
  )

  (footprint "TerminalBlock:TerminalBlock_KF301-2P:J3"
    (layer "F.Cu")
    (at 140 10)
    (descr "Water Level Sensor")
    (tags "sensor water")
    (property "Reference" "J3" (at 140 5) (layer "F.SilkS"))
    (property "Value" "水位检测" (at 140 15) (layer "F.Fab"))
    (property "Footprint" "TerminalBlock:TerminalBlock_KF301-2P" (at 140 20) (layer "F.Fab"))
    (property "LCSC" "C20959" (at 140 25) (layer "F.Fab"))
    (attr through_hole)
  )

  (footprint "TerminalBlock:TerminalBlock_KF301-2P:J4"
    (layer "F.Cu")
    (at 250 70)
    (descr "Water Pump")
    (tags "pump water")
    (property "Reference" "J4" (at 250 65) (layer "F.SilkS"))
    (property "Value" "水泵" (at 250 75) (layer "F.Fab"))
    (property "Footprint" "TerminalBlock:TerminalBlock_KF301-2P" (at 250 80) (layer "F.Fab"))
    (property "LCSC" "C20959" (at 250 85) (layer "F.Fab"))
    (attr through_hole)
  )

  (footprint "TerminalBlock:TerminalBlock_KF301-2P:J5"
    (layer "F.Cu")
    (at 160 10)
    (descr "NTC Temperature Sensor")
    (tags "NTC temperature")
    (property "Reference" "J5" (at 160 5) (layer "F.SilkS"))
    (property "Value" "NTC" (at 160 15) (layer "F.Fab"))
    (property "Footprint" "TerminalBlock:TerminalBlock_KF301-2P" (at 160 20) (layer "F.Fab"))
    (property "LCSC" "C20959" (at 160 25) (layer "F.Fab"))
    (attr through_hole)
  )

  (gr_line (start 0 0) (end 180 0) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 180 0) (end 180 120) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 180 120) (end 0 120) (layer "Edge.Cuts") (width 0.05))
  (gr_line (start 0 120) (end 0 0) (layer "Edge.Cuts") (width 0.05))

  (zone
    (net 1)
    (net_name "GND")
    (layer "B.Cu")
    (hatch edge 0.508)
    (connect_pads (clearance 0.3))
    (min_thickness 0.254)
    (filled_areas_thickness no)
    (fill
      (thermal_gap 0.508)
      (thermal_bridge_width 0.508)
    )
    (polygon
      (pts
        (xy 5 5)
        (xy 175 5)
        (xy 175 115)
        (xy 5 115)
      )
    )
  )

  (segment (start 50 25) (end 50 30) (width 1.0) (layer "F.Cu") (net 3))
  (segment (start 50 75) (end 50 80) (width 1.0) (layer "F.Cu") (net 8))
  (segment (start 100 105) (end 100 110) (width 0.5) (layer "F.Cu") (net 2))
  (segment (start 150 105) (end 150 110) (width 1.0) (layer "F.Cu") (net 9))
  (segment (start 200 75) (end 200 80) (width 1.0) (layer "F.Cu") (net 11))

  (via (at 50 50) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 100 80) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))
  (via (at 150 50) (size 0.6) (drill 0.3) (layers "F.Cu" "B.Cu") (net 1))

  (notes
    "板框尺寸：180×120mm"
    "层数：2 层"
    "板厚：1.6mm"
    "铜厚：1oz (35μm)"
    "阻焊：绿色"
    "丝印：白色"
    "底层完整 GND 铺铜"
    "NTC 热敏电阻需飞线到电池表面"
    "电源走线宽度≥1.0mm"
    "ESP32 天线区域禁止铺铜"
    "v0.4 简化版：单节 18650+TP4056"
  )
)
